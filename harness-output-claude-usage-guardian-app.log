": [\n        \"bin/check.js\"\n      ],\n      \"acceptance\": [\n        \"Exit code 0 when usage is below pause threshold\",\n        \"Exit code 1 when usage is at/above pause but below stop\",\n        \"Exit code 2 when usage is at/above stop threshold\",\n        \"JSON output to stdout with detailed usage info\"\n      ],\n      \"dependencies\": []\n    },\n    {\n      \"id\": \"CORE-003\",\n      \"name\": \"Desktop Screenshot Scraper\",\n      \"description\": \"AppleScript + Vision OCR + cliclick to extract usage from Claude Settings page\",\n      \"priority\": \"P0\",\n      \"phase\": 1,\n      \"effort\": \"4h\",\n      \"passes\": true,\n      \"status\": \"completed\",\n      \"category\": \"core\",\n      \"files\": [\n        \"bin/scrape.sh\"\n      ],\n      \"acceptance\": [\n        \"Opens Claude app and navigates to Settings > Usage\",\n        \"Takes screenshot of usage page (top and scrolled view)\",\n        \"Uses macOS Vision framework for OCR text extraction\",\n        \"Handles window positioning and click automation via cliclick\",\n        \"Writes JSON output to data/claude-usage.json\"\n      ],\n      \"dependencies\": []\n    },\n    {\n      \"id\": \"CORE-004\",\n      \"name\": \"OCR Text Parser\",\n      \"description\": \"Python script to extract usage percentages, reset times, and costs from OCR text\",\n      \"priority\": \"P0\",\n      \"phase\": 1,\n      \"effort\": \"2h\",\n      \"passes\": true,\n      \"status\": \"completed\",\n      \"category\": \"core\",\n      \"files\": [\n        \"lib/parse-usage.py\"\n      ],\n      \"acceptance\": [\n        \"Extracts session, weekly (all models), and weekly (Sonnet) percentages\",\n        \"Parses reset times and durations\",\n        \"Extracts extra spend and credit balance\",\n        \"Calculates max_weekly_percent for primary signal\",\n        \"Handles missing/incomplete OCR gracefully\"\n      ],\n      \"dependencies\": []\n    },\n    {\n      \"id\": \